{
  "name": "diuqbank-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "api:types": "pnpm --filter diuqbank-api run openapi:emit && openapi-typescript ../api/openapi.json -o src/types/openapi.ts",
    "api:types:remote": "openapi-typescript https://diuqbank-api-prod.sourov-cse.workers.dev/openapi.json -o src/types/openapi.ts",
    "verify": "pnpm run lint && pnpm run build",
    "build": "pnpm run typecheck && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "cf:dev": "wrangler dev",
    "deploy:dry-run": "pnpm run verify && wrangler deploy --dry-run --outdir /tmp/diuqbank-web-dryrun",
    "deploy": "pnpm run verify && wrangler deploy"
  },
  "dependencies": {
    "@diuqbank/shared": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.71.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.1",
    "wrangler": "^4.106.0"
  }
}
