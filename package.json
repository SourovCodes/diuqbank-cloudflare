{
  "name": "diuqbank-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @diuqbank/api dev",
    "dev:web": "pnpm --filter @diuqbank/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "deploy:api": "pnpm --filter @diuqbank/api run deploy",
    "deploy:web": "pnpm --filter @diuqbank/web run deploy"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  }
}
