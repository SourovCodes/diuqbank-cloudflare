{
  "name": "diuqbank",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter diuqbank-api --filter diuqbank-web run dev",
    "dev:api": "pnpm --filter diuqbank-api run dev",
    "dev:web": "pnpm --filter diuqbank-web run dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "deploy:api": "pnpm --filter diuqbank-api run deploy",
    "deploy:web": "pnpm --filter diuqbank-web run deploy",
    "db:generate": "pnpm --filter diuqbank-api run db:generate",
    "db:migrate:local": "pnpm --filter diuqbank-api run db:migrate:local",
    "db:migrate:remote": "pnpm --filter diuqbank-api run db:migrate:remote",
    "cf-typegen": "pnpm --filter diuqbank-api run cf-typegen"
  }
}
