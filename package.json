{
  "name": "diuqbank-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @diuqbank/api --filter @diuqbank/web dev",
    "dev:api": "pnpm --filter @diuqbank/api dev",
    "dev:web": "pnpm --filter @diuqbank/web dev",
    "build": "pnpm -r --if-present build",
    "api:generate": "pnpm --filter @diuqbank/api-client generate",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "deploy:api": "pnpm --filter @diuqbank/api run deploy",
    "deploy:web": "pnpm --filter @diuqbank/web run deploy"
  }
}
